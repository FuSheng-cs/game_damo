# DAMO 后端环境变量配置示例
# 复制此文件为 .env，然后填写你的配置

# ============================================================
# 服务器端 LLM 配置（可选）
# 如果配置了服务器端 Key，玩家无需填写 Key 即可直接游玩。
# 如果没有配置，玩家必须在游戏设置页面填入自己的 API Key。
# ============================================================

# LLM 服务商（可选值：openai / qwen / doubao）
# LLM_PROVIDER=qwen

# LLM API Key（从对应服务商控制台获取）
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# LLM 模型名称（留空则使用各 Provider 的默认模型）
# 各 Provider 默认模型：
#   openai  → gpt-4o-mini
#   qwen    → qwen-plus
#   doubao  → doubao-pro-4k
# LLM_MODEL=qwen-plus

# 自定义 Base URL（可选，用于 API 中转或自建服务）
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================================
# 服务器配置
# ============================================================

# 后端监听端口（默认 8080）
# PORT=8080
